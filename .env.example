MATON_BASE_URL=https://www.maton.ai
MATON_CALLBACK_BASE_URL=https://maton.ai
MATON_FALLBACK_URL=https://maton.ai
DEFAULT_DOMAIN=iosos.cloudns.biz
PORT=8787

# Optional: IMAP polling for actual mail body links.
MAIL_LISTEN=false
MAIL_IMAP_HOST=
MAIL_IMAP_PORT=993
MAIL_IMAP_SECURE=true
MAIL_USER=
MAIL_PASSWORD=
MAIL_MAILBOX=INBOX
MAIL_POLL_SECONDS=5
MAIL_LOOKBACK=20

# Optional: Telegram MTProto user listener for Seek bot messages.
TELEGRAM_LISTEN=false
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
# Optional: only accept messages from this Telegram username, without @.
TELEGRAM_SOURCE_USERNAME=
# Optional SOCKS proxy for Telegram MTProto, useful on restricted networks.
TELEGRAM_PROXY_HOST=
TELEGRAM_PROXY_PORT=
TELEGRAM_PROXY_SOCKS_TYPE=5
